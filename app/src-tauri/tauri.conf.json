{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YTM Board Bridge",
  "version": "1.0.1",
  "identifier": "app.ytmboard.bridge",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "YT Music Board Bridge",
        "width": 480,
        "height": 360,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
